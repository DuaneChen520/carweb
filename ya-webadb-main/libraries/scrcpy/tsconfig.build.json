{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "rootDir": "src",
        "outDir": "esm",
        "lib": ["ES2021", "DOM"],
        "strict": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": []
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "esm"]
}
